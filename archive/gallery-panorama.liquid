<style>
#wlw-gallery *, #wlw-gallery *::before, #wlw-gallery *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

#wlw-gallery {
  --pink: #FF3E8E;
  --yellow: #E8FF00;
  --bg: #0a0a0a;
  --font-display: 'Nimbus Sans', 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
  --font-mono: 'Space Mono', 'Courier New', monospace;

  position: relative;
  width: 100vw;
  margin-left: calc(-50vw + 50%);
  height: 100vh;
  background: var(--bg);
  font-family: var(--font-mono);
  overflow: hidden;
}

/* Pannellum container */
#wlw-panorama {
  width: 100%;
  height: 100%;
}

/* Hide Pannellum UI */
#wlw-gallery .pnlm-about-msg,
#wlw-gallery .pnlm-orientation-button,
#wlw-gallery .pnlm-zoom-controls,
#wlw-gallery .pnlm-fullscreen-toggle-button-inactive,
#wlw-gallery .pnlm-hot-spot-debug-indicator,
#wlw-gallery .pnlm-load-box,
#wlw-gallery .pnlm-compass {
  display: none !important;
}

/* Hotspot base reset */
#wlw-gallery div.pnlm-hotspot-base {
  background: none !important;
  border: none !important;
  box-shadow: none !important;
  width: 0 !important;
  height: 0 !important;
  overflow: visible !important;
}

#wlw-gallery div.pnlm-hotspot-base .pnlm-pointer,
#wlw-gallery div.pnlm-hotspot-base .pnlm-sprite {
  display: none !important;
}

#wlw-gallery .pnlm-tooltip span {
  display: none !important;
}

/* Painting frame */
#wlw-gallery .pf {
  position: relative;
  left: -75px;
  top: -90px;
  width: 150px;
  background: #f5f0eb;
  padding: 8px;
  padding-bottom: 24px;
  box-shadow: 0 3px 15px rgba(0,0,0,0.4), 0 0 0 1px rgba(0,0,0,0.08);
  transition: transform 0.3s, box-shadow 0.3s;
  cursor: pointer;
  display: block;
  text-decoration: none;
}

#wlw-gallery .pf:hover {
  transform: scale(1.1);
  box-shadow: 0 8px 40px rgba(255,62,142,0.5), 0 0 0 2px var(--pink);
  z-index: 10;
}

#wlw-gallery .pf img {
  display: block;
  width: 134px;
  height: auto;
  max-height: 170px;
  object-fit: cover;
}

#wlw-gallery .pf .ptitle {
  text-align: center;
  font-family: 'Inter', sans-serif;
  font-size: 7px;
  color: #333;
  letter-spacing: 0.5px;
  margin-top: 6px;
  text-transform: uppercase;
}

/* Hover label */
#wlw-gallery .pl {
  position: absolute;
  bottom: -55px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.92);
  color: #fff;
  padding: 8px 14px;
  font-size: 9px;
  letter-spacing: 1px;
  white-space: nowrap;
  text-align: center;
  border: 1px solid rgba(255,62,142,0.2);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

#wlw-gallery .pf:hover .pl {
  opacity: 1;
}

#wlw-gallery .pl b {
  font-family: var(--font-display);
  font-size: 12px;
  display: block;
  margin-bottom: 2px;
}

#wlw-gallery .pl small {
  color: #888;
}

#wlw-gallery .pl i {
  color: var(--yellow);
  font-style: normal;
  font-weight: 700;
}

/* HUD */
#wlw-hud {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 50;
  padding: 16px 24px;
  display: flex;
  justify-content: center;
  align-items: center;
  background: linear-gradient(rgba(0,0,0,0.5), transparent);
  pointer-events: none;
}

#wlw-hud .brand {
  font-family: var(--font-display);
  font-weight: 900;
  font-size: 16px;
  color: var(--pink);
  letter-spacing: 0.15em;
}

#wlw-hud .controls {
  position: absolute;
  right: 24px;
  color: rgba(255,255,255,0.4);
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
}

/* Thumbnail strip */
#wlw-strip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 60;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  padding: 12px 20px;
  display: flex;
  gap: 8px;
  overflow-x: auto;
  white-space: nowrap;
  scrollbar-width: none;
}

#wlw-strip::-webkit-scrollbar {
  display: none;
}

#wlw-strip a {
  flex-shrink: 0;
  display: inline-block;
  width: 48px;
  height: 48px;
  border: 2px solid rgba(255,255,255,0.1);
  cursor: pointer;
  transition: all 0.3s;
  text-decoration: none;
}

#wlw-strip a:hover {
  border-color: var(--pink);
  transform: scale(1.15);
}

#wlw-strip a img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  opacity: 0.6;
  transition: opacity 0.3s;
}

#wlw-strip a:hover img {
  opacity: 1;
}

/* Mobile fallback grid */
#wlw-mobile-grid {
  display: none;
}

@media (max-width: 768px) {
  #wlw-gallery {
    height: auto;
    min-height: unset;
  }

  #wlw-panorama,
  #wlw-strip {
    display: none !important;
  }

  #wlw-hud {
    position: relative;
    background: var(--bg);
    justify-content: center;
    padding: 24px 16px 8px;
  }

  #wlw-hud .controls {
    display: none;
  }

  #wlw-mobile-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    padding: 8px 16px 24px;
    background: var(--bg);
  }

  #wlw-mobile-grid a {
    display: block;
    text-decoration: none;
    background: #111;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  #wlw-mobile-grid a:hover {
    border-color: var(--pink);
  }

  #wlw-mobile-grid a img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }

  #wlw-mobile-grid .mg-info {
    padding: 8px 10px;
  }

  #wlw-mobile-grid .mg-title {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    display: block;
    margin-bottom: 2px;
  }

  #wlw-mobile-grid .mg-meta {
    font-family: var(--font-mono);
    font-size: 9px;
    color: rgba(255,255,255,0.5);
    display: block;
  }

  #wlw-mobile-grid .mg-price {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--yellow);
    display: block;
    margin-top: 4px;
  }
}

@media (max-width: 420px) {
  #wlw-mobile-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<div id="wlw-gallery">
  <div id="wlw-hud">
    <div class="brand">WladislaW</div>
    <div class="controls">Drag &middot; Zoom &middot; Click</div>
  </div>

  <div id="wlw-panorama"></div>
  <div id="wlw-strip"></div>
  <div id="wlw-mobile-grid"></div>
</div>

<script>
(function() {
  'use strict';

  /* --- Dynamically load Pannellum CSS --- */
  var css = document.createElement('link');
  css.rel = 'stylesheet';
  css.href = 'https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.css';
  document.head.appendChild(css);

  /* --- Dynamically load Google Fonts --- */
  var fonts = document.createElement('link');
  fonts.rel = 'stylesheet';
  fonts.href = 'https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap';
  document.head.appendChild(fonts);

  var CDN = 'https://cdn.shopify.com/s/files/1/1013/4650/9142/files/';
  var PANORAMA_URL = CDN + 'mirrored_hall.jpg?v=1774068524';

  // Paintings placed logically on walls of the mirrored hall:
  // - SPIEGELWAND (yaw -165 to -125): Above/between the 3 large mirrors, pitch 12-15 (high, above mirror frames)
  // - WANDPANEELE links (yaw -110): Wall panel next to door
  // - FENSTERPFEILER (yaw -85, -65, -45): Narrow wall pillars between windows
  // - WANDSEKTION rechts (yaw +65 to +150): Solid wall panels with wood paneling
  // - Avoid: windows (yaw -100 to -35 lower areas), doors (yaw -115, +108)
  var PAINTINGS = [
    // === SPIEGELWAND: 4 paintings above the 3 mirrors (high up, decorative wall) ===
    { title: 'Selbstportrait mit Trommel', size: '100\u00d7120 cm', price: 'CHF 4.200', year: '2023', handle: 'selbstportrait-mit-trommel', img: CDN+'painting_02.jpg?v=1774065825', pitch: 14, yaw: -158 },
    { title: 'The Kiss',                  size: '120\u00d760 cm',  price: 'CHF 3.800', year: '2021', handle: 'the-kiss',                  img: CDN+'painting_01.jpg?v=1774065825', pitch: 14, yaw: -145 },
    { title: 'Luchador Mask',             size: '80\u00d780 cm',   price: 'CHF 2.400', year: '2019', handle: 'luchador-mask',             img: CDN+'painting_00.jpg?v=1774065825', pitch: 14, yaw: -135 },
    { title: '\u0412\u041e\u041b\u041a (Wolf)',             size: '70\u00d790 cm',   price: 'CHF 2.800', year: '2020', handle: 'volk-wolf',                  img: CDN+'painting_03.jpg?v=1774065825', pitch: 14, yaw: -125 },

    // === WANDPANEEL links neben Tür: 1 painting ===
    { title: 'Purple Figure',             size: '80\u00d7100 cm',  price: 'CHF 2.600', year: '2021', handle: 'purple-figure',             img: CDN+'painting_04.jpg?v=1774065825', pitch: 5, yaw: -108 },

    // === FENSTERPFEILER: 3 paintings on narrow pillars between windows ===
    { title: 'Pink Faces',                size: '60\u00d7120 cm',  price: 'CHF 3.200', year: '2019', handle: 'pink-faces',                img: CDN+'painting_05.jpg?v=1774065825', pitch: 8, yaw: -85  },
    { title: 'Dark Portrait',             size: '80\u00d780 cm',   price: 'CHF 2.400', year: '2019', handle: 'dark-portrait',             img: CDN+'painting_06.jpg?v=1774065825', pitch: 8, yaw: -60  },
    { title: 'Reclining Figure',          size: '80\u00d780 cm',   price: 'CHF 2.400', year: '2020', handle: 'reclining-figure',          img: CDN+'painting_07.jpg?v=1774065825', pitch: 8, yaw: -42  },

    // === RECHTE WANDSEKTION: 7 paintings on solid wall panels ===
    { title: 'Extended Hand',             size: '80\u00d780 cm',   price: 'CHF 2.100', year: '2020', handle: 'extended-hand',             img: CDN+'painting_08.jpg?v=1774065825', pitch: 5, yaw: 65   },
    { title: 'Fist',                      size: '80\u00d780 cm',   price: 'CHF 2.100', year: '2020', handle: 'fist',                      img: CDN+'painting_09.jpg?v=1774065825', pitch: 5, yaw: 80   },
    { title: 'Hand on Black',             size: '80\u00d780 cm',   price: 'CHF 2.400', year: '2019', handle: 'hand-on-black',             img: CDN+'painting_10.jpg?v=1774065825', pitch: 5, yaw: 95   },
    { title: 'Pink Rabbit',              size: '60\u00d780 cm',   price: 'CHF 2.200', year: '2021', handle: 'pink-rabbit',               img: CDN+'painting_11.jpg?v=1774065825', pitch: 5, yaw: 120  },
    { title: 'Rabbit II',                size: '60\u00d780 cm',   price: 'CHF 2.200', year: '2021', handle: 'rabbit-ii',                 img: CDN+'painting_12.jpg?v=1774065825', pitch: 5, yaw: 135  },
    { title: 'Figure on Pink',           size: '60\u00d780 cm',   price: 'CHF 2.800', year: '2022', handle: 'figure-on-pink',            img: CDN+'painting_13.jpg?v=1774065825', pitch: 5, yaw: 150  },
    { title: 'Rabbit on Yellow',         size: '60\u00d780 cm',   price: 'CHF 1.900', year: '2021', handle: 'rabbit-on-yellow',          img: CDN+'painting_14.jpg?v=1774065825', pitch: 5, yaw: 165  }
  ];

  var isMobile = window.innerWidth <= 768;

  // Mobile: render grid
  if (isMobile) {
    var grid = document.getElementById('wlw-mobile-grid');
    PAINTINGS.forEach(function(p) {
      var a = document.createElement('a');
      a.href = '/products/' + p.handle;
      a.innerHTML =
        '<img src="' + p.img + '" alt="' + p.title + '" loading="lazy">' +
        '<div class="mg-info">' +
          '<span class="mg-title">' + p.title + '</span>' +
          '<span class="mg-meta">' + p.size + ' &middot; ' + p.year + '</span>' +
          '<span class="mg-price">' + p.price + '</span>' +
        '</div>';
      grid.appendChild(a);
    });
    return;
  }

  /* --- Dynamically load Pannellum JS, then initialize --- */
  var js = document.createElement('script');
  js.src = 'https://cdn.jsdelivr.net/npm/pannellum@2.5.6/build/pannellum.js';
  js.onload = function() {

    // Desktop: Pannellum
    function makeTooltip(hotSpotDiv, args) {
      var p = PAINTINGS[args];
      var frame = document.createElement('a');
      frame.href = '/products/' + p.handle;
      frame.className = 'pf';

      var img = document.createElement('img');
      img.src = p.img;
      frame.appendChild(img);

      var titleDiv = document.createElement('div');
      titleDiv.className = 'ptitle';
      titleDiv.textContent = p.title;
      frame.appendChild(titleDiv);

      var label = document.createElement('div');
      label.className = 'pl';
      label.innerHTML = '<b>' + p.title + '</b><small>' + p.size + ' &middot; ' + p.year + '</small><br><i>' + p.price + '</i>';
      frame.appendChild(label);

      hotSpotDiv.appendChild(frame);
    }

    var hotspots = PAINTINGS.map(function(p, i) {
      return {
        pitch: p.pitch,
        yaw: p.yaw,
        type: 'custom',
        cssClass: 'painting-hs',
        createTooltipFunc: makeTooltip,
        createTooltipArgs: i
      };
    });

    pannellum.viewer('wlw-panorama', {
      type: 'equirectangular',
      panorama: PANORAMA_URL,
      crossOrigin: 'anonymous',
      autoLoad: true,
      showControls: false,
      compass: false,
      hfov: 100,
      minHfov: 50,
      maxHfov: 120,
      pitch: 5,
      yaw: -145,
      autoRotate: -1.5,
      autoRotateInactivityDelay: 4000,
      hotSpots: hotspots
    });

    // Thumbnail strip
    var strip = document.getElementById('wlw-strip');
    PAINTINGS.forEach(function(p) {
      var a = document.createElement('a');
      a.href = '/products/' + p.handle;
      a.title = p.title;
      var img = document.createElement('img');
      img.src = p.img;
      img.alt = p.title;
      a.appendChild(img);
      strip.appendChild(a);
    });

  };
  document.head.appendChild(js);

})();
</script>

