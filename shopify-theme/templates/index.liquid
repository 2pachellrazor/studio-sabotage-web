{% layout 'blank' %}

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/x-icon" href="{{ 'favicon.ico' | asset_url }}">
<link rel="icon" type="image/png" sizes="32x32" href="{{ 'favicon-32x32.png' | asset_url }}">
<link rel="icon" type="image/png" sizes="192x192" href="{{ 'favicon-192x192.png' | asset_url }}">
<link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch-icon.png' | asset_url }}">
<title>Studio Sabotage — Expressionistische Ölmalerei | WladislaW</title>
<meta name="description" content="Studio Sabotage — immersive 3D-Kunstgalerie von WladislaW Mueller. Expressionistische Ölmalerei, Graffiti & Mixed Media. Originale kaufen direkt vom Künstler.">
<meta property="og:title" content="Studio Sabotage — Expressionistische Ölmalerei | WladislaW">
<meta property="og:description" content="Immersive 3D-Kunstgalerie. Expressionistische Ölmalerei, Graffiti & Mixed Media direkt vom Künstler.">
<meta property="og:image" content="https://cdn.shopify.com/s/files/1/1013/4650/9142/files/painting_02.jpg?v=1774065825">
<meta property="og:type" content="website">
<meta property="og:url" content="https://studiosabotage.com">
<link rel="canonical" href="https://studiosabotage.com">
<link rel="stylesheet" href="{{ 'landing.css' | asset_url }}">

<canvas id="particleBg" aria-hidden="true"></canvas>
<div id="vignette" aria-hidden="true"></div>

<div id="content" role="main">
  <div id="brand-block">
    <p id="brand-name">Studio Sabotage</p>
    <canvas id="logo3d" width="380" height="632"></canvas>
    <img id="tag-img" src="{{ 'tag.png' | asset_url }}" alt="Studio Sabotage Tag">
  </div>
  <p id="parental-advisory">Parental Advisory — Explicit Content</p>
  <a id="cta" href="/pages/gallery">Enter Anyway</a>
</div>

<div id="footer">
  <span style="font-weight:700; color:rgba(255,255,255,0.5);">WladislaW — Frankfurt</span>
  <div style="display:flex; gap:24px;">
    <a href="https://instagram.com/babydonthvrtme" target="_blank" rel="noopener noreferrer">@babydonthvrtme</a>
    <span>&middot;</span>
    <a href="/pages/gallery#impressum" style="color:rgba(255,255,255,0.3); text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='rgba(255,255,255,0.6)'" onmouseout="this.style.color='rgba(255,255,255,0.3)'">Impressum</a>
    <span>&copy; 2026</span>
  </div>
</div>

<script>
  window.SS_ASSETS = {
    logoPng: '{{ "logo.png" | asset_url }}',
    snakeVertical: '{{ "snake-vertical.png" | asset_url }}',
    tagPng: '{{ "tag.png" | asset_url }}'
  };
</script>
<script src="{{ 'landing.js' | asset_url }}"></script>

{% render 'cookie-consent' %}
