</div>

<!-- Hotspot Hover Hint -->
<div id="hotspot-hint"></div>

<!-- Info Panel -->
<div id="info-panel" role="dialog" aria-modal="true" aria-labelledby="panel-title">
  <button class="close-btn" id="close-panel-btn" aria-label="Schließen">&times;</button>
  <div class="panel-header">
    <div class="panel-category" id="panel-category"></div>
    <div class="panel-title" id="panel-title"></div>
  </div>
  <div class="panel-body">
    <div class="panel-text" id="panel-text"></div>
    <div class="panel-detail" id="panel-detail"></div>
  </div>
  <div class="close-hint">ESC or click to close</div>
</div>

<!-- Hotspot Container -->
<div id="hotspot-container" style="position:fixed;inset:0;z-index:40;pointer-events:none;"></div>

