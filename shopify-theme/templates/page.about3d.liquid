  <div class="status" id="load-status">initialisiere...</div>
</div>

<a href="#page-footer" class="skip-nav" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999;padding:8px 16px;background:var(--ss-neon);color:#fff;font-family:'Nimbus Sans',sans-serif;font-size:0.85rem;text-decoration:none;" onfocus="this.style.cssText='position:fixed;left:16px;top:16px;width:auto;height:auto;overflow:visible;z-index:9999;padding:8px 16px;background:var(--ss-neon);color:#fff;font-family:Nimbus Sans,sans-serif;font-size:0.85rem;text-decoration:none;'" onblur="this.style.cssText='position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999;'">Zum Inhalt springen</a>

<!-- Resume overlay -->
<div id="overlay" class="hidden" role="dialog" aria-modal="true" aria-label="Szene pausiert">
  <span class="resume-text">Click to keep looking</span>
</div>

<!-- Crosshair -->
<div id="crosshair" aria-hidden="true"></div>

<!-- Controls hint -->
<div id="controls-hint" style="display:none;">
